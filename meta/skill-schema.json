{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/SamoTech/skills-tree/raw/main/meta/skill-schema.json",
  "title": "AI Agent Skill",
  "description": "Schema for a single AI Agent Skill file in the SamoTech/skills-tree repository.",
  "type": "object",
  "required": ["title", "category", "level", "stability", "added", "description"],
  "properties": {
    "title": {
      "type": "string",
      "description": "Human-readable skill name, e.g. 'Chain-of-Thought Reasoning'"
    },
    "category": {
      "type": "string",
      "description": "Category slug, e.g. '02-reasoning'",
      "enum": [
        "01-perception",
        "02-reasoning",
        "03-memory",
        "04-action-execution",
        "05-code",
        "06-communication",
        "07-tool-use",
        "08-multimodal",
        "09-agentic-patterns",
        "10-computer-use",
        "11-web",
        "12-data",
        "13-creative",
        "14-security",
        "15-orchestration",
        "16-domain-specific"
      ]
    },
    "level": {
      "type": "string",
      "description": "Skill difficulty level",
      "enum": ["basic", "intermediate", "advanced", "experimental"]
    },
    "stability": {
      "type": "string",
      "description": "How stable/mature this skill is",
      "enum": ["stable", "experimental", "deprecated"]
    },
    "added": {
      "type": "string",
      "description": "Month when the skill was first added, format YYYY-MM",
      "pattern": "^[0-9]{4}-[0-9]{2}$"
    },
    "last_updated": {
      "type": "string",
      "description": "Month of last update, format YYYY-MM",
      "pattern": "^[0-9]{4}-[0-9]{2}$"
    },
    "description": {
      "type": "string",
      "description": "1-3 sentence description of what this skill enables an agent to do"
    },
    "related_skills": {
      "type": "array",
      "description": "List of related skill file paths relative to the skills/ root",
      "items": { "type": "string" }
    },
    "frameworks": {
      "type": "array",
      "description": "Frameworks or models that implement this skill",
      "items": {
        "type": "object",
        "required": ["name", "url"],
        "properties": {
          "name": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "implementation": { "type": "string" },
          "since": { "type": "string" }
        }
      }
    }
  },
  "additionalProperties": false
}
