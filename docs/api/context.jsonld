{
  "@context": {
    "@version": 1.1,
    "@vocab": "https://schema.org/",
    "ai-skill": "https://samotech.github.io/skills-tree/api/context#",

    "skillId": {
      "@id": "ai-skill:skillId",
      "@type": "@id"
    },
    "skillVersion": {
      "@id": "ai-skill:skillVersion"
    },
    "skillLevel": {
      "@id": "ai-skill:skillLevel"
    },
    "skillStability": {
      "@id": "ai-skill:skillStability"
    },
    "categoryDir": {
      "@id": "ai-skill:categoryDir"
    },
    "sections": {
      "@id": "ai-skill:sections",
      "@container": "@list"
    },
    "relatedSkills": {
      "@id": "ai-skill:relatedSkills",
      "@container": "@list"
    },
    "failureModes": {
      "@id": "ai-skill:failureModes"
    },
    "promptPatterns": {
      "@id": "ai-skill:promptPatterns"
    }
  }
}
